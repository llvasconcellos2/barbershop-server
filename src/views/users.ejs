<%-include('partials/header.ejs') %>
<%-include('partials/navbar.ejs') %>
<div class="content">
  <% if(users.length > 0) { %>
    <% users.forEach(user => { %>
      <h3 class="title"><%=user.firstName + ' ' + user.lastName %></h3>
      <p><%=user.email %></p>
    <% }); %>
  <% } else { %> 
    <p>No Users Found.</p>  
  <% } %>
</div>
<%-include('partials/footer.ejs') %>